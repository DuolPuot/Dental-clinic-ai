# ─── Application ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── MongoDB ─────────────────────────────────────────────────────────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=changeme
MONGO_DB_NAME=dental_clinic
MONGODB_URI=mongodb://admin:changeme@localhost:27017/dental_clinic?authSource=admin

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=changeme
REDIS_URL=redis://:changeme@localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change-this-access-secret-to-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=change-this-refresh-secret-to-a-long-random-string-min-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── AWS S3 ──────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=dental-clinic-files
AWS_REGION=us-east-1

# ─── SMTP (Nodemailer) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@dentalclinic.example.com

# ─── Twilio (SMS) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
