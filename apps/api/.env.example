# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ─── MongoDB Atlas ────────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── JWT Secrets (generate with: openssl rand -hex 64) ───────────────────────
JWT_ACCESS_SECRET=<min-32-char-random-string>
JWT_REFRESH_SECRET=<min-32-char-random-string>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── OpenAI ──────────────────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ─── AWS S3 (optional — for X-ray uploads) ───────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# ─── SMTP Email ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=duolpuot06@gmail.com
SMTP_PASS=<app-password>
EMAIL_FROM=duolpuot06@gmail.com

# ─── Twilio (SMS / WhatsApp) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+251996251606
TWILIO_WHATSAPP_FROM=whatsapp:+251996251606

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=https://your-frontend-domain.com
