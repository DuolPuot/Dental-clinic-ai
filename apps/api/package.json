{
  "name": "@dental-clinic/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "build": "tsc --project tsconfig.json --noEmitOnError false",
    "start": "node dist/index.js",
    "start:dev": "tsx --env-file=.env src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "seed": "tsx --env-file=.env src/scripts/seed.ts"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.600.0",
    "@aws-sdk/s3-request-presigner": "3.600.0",
    "@trpc/server": "^10.45.2",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jose": "^5.2.4",
    "mongoose": "^8.3.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.13",
    "openai": "^4.38.5",
    "pdfkit": "^0.15.0",
    "twilio": "^5.0.4",
    "uuid": "^9.0.1",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.14",
    "@types/pdfkit": "^0.13.4",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^1.5.0",
    "supertest": "^7.0.0",
    "tsx": "^4.7.3",
    "typescript": "^5.3.3",
    "vitest": "^1.5.0"
  }
}
